# Slack — create an app at https://api.slack.com/apps
# Required bot token scopes: chat:write, im:history, im:read, im:write
# Required events: message.im
# Enable Socket Mode and generate an App-Level Token with connections:write scope
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# Postgres connection string
DATABASE_URL=postgresql://gymlog:gymlog@localhost:5432/gymlog

# OpenAI
OPENAI_API_KEY=sk-...
